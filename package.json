{
  "name": "site-to-pdf",
  "version": "0.9.0",
  "description": "CLI tool that fetches a URL, extracts page content, and generates a PDF",
  "main": "electron/main.js",
  "bin": {
    "site-to-pdf": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/",
    "test": "jest",
    "electron": "npm run build && electron .",
    "electron:dev": "npm run build && electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "pdf",
    "web-scraper",
    "cli",
    "content-extraction"
  ],
  "author": "AvishalomJ",
  "license": "MIT",
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.1",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "electron-updater": "^6.6.2",
    "fastify": "^5.8.5",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.52.0",
    "uuid": "^13.0.0",
    "youtube-dl-exec": "^3.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.sitetopdf.app",
    "productName": "SiteToPdf",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AvishalomJ",
        "repo": "SiteToPdf"
      }
    ]
  }
}
