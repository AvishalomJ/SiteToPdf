{
  "name": "site-to-pdf",
  "version": "0.3.9",
  "description": "CLI tool that fetches a URL, extracts page content, and generates a PDF",
  "main": "electron/main.js",
  "bin": {
    "site-to-pdf": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/",
    "test": "jest",
    "electron": "npm run build && electron .",
    "electron:dev": "npm run build && electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "pdf",
    "web-scraper",
    "cli",
    "content-extraction"
  ],
  "author": "AvishalomJ",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "electron-updater": "^6.6.2",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.sitetopdf.app",
    "productName": "SiteToPdf",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AvishalomJ",
        "repo": "SiteToPdf"
      }
    ]
  }
}
